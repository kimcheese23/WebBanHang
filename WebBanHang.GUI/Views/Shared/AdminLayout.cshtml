<!DOCTYPE html>
<html>
<head>
    <title>Admin - @ViewBag.Title</title>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <nav class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">
            <h4>Quản trị</h4>
            <ul class="nav flex-column mt-3">
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Dashboard">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Users">Người dùng</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Orders">Hóa đơn</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Product/Index">Sản phẩm</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Account/Logout">Đăng xuất</a></li>
            </ul>
        </nav>

        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
