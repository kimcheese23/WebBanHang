<!DOCTYPE html>
<html>
<head>
    <title>Admin - @ViewBag.Title</title>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <nav class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">
            <h4>Quản trị</h4>
            <ul class="nav flex-column mt-3">
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Dashboard">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Categories">Danh mục</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Products">Sản phẩm</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Admin/Orders">Hóa đơn</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="/Account/Logout">Đăng xuất</a></li>
            </ul>
        </nav>

        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>

    @RenderSection("Scripts", required: false)

    
    <script>
            async function callApi(url, method = 'GET', data = null) {
                const options = {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    }
                };

                if (data) {
                    options.body = JSON.stringify(data);
                }

                try {
                    const response = await fetch(url, options);
            
                    if (response.status === 204) return true;

                    const result = await response.json();
                    if (!response.ok) {
                        alert(result.message || "Có lỗi xảy ra!");
                        return null;
                    }
                    return result;
                } catch (error) {
                    console.error("API Error:", error);
                    alert("Không thể kết nối tới server.");
                    return null;
                }
            }
    </script>
</body>
</html>
