@model WebBanHang.GUI.Models.RegisterVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Đăng ký";
}

<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="text-center mb-4">Đăng ký thành viên</h2>
        
        <form id="registerForm">
            <div id="registerError" class="alert alert-danger d-none"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label"><span class="text-danger">*</span> Tên đăng nhập</label>
                    <input type="text" id="reg_username" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label"><span class="text-danger">*</span> Email</label>
                    <input type="email" id="reg_email" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label"><span class="text-danger">*</span> Mật khẩu</label>
                    <input type="password" id="reg_password" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label"><span class="text-danger">*</span> Xác nhận mật khẩu</label>
                    <input type="password" id="reg_confirm" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Ngày sinh</label>
                    <input type="date" id="reg_dob" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Địa chỉ</label>
                    <input type="text" id="reg_address" class="form-control" />
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success px-5">Đăng ký</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <small>Bạn đã có tài khoản? <a asp-controller="Account" asp-action="Login">Đăng nhập ngay</a></small>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('registerForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            
            const errorDiv = document.getElementById('registerError');
            errorDiv.classList.add('d-none');
            errorDiv.innerHTML = ""; // Xóa nội dung cũ

            const password = document.getElementById('reg_password').value;
            const confirm = document.getElementById('reg_confirm').value;

            if (password !== confirm) {
                errorDiv.textContent = "Mật khẩu xác nhận không khớp!";
                errorDiv.classList.remove('d-none');
                return;
            }

            const data = {
                UserName: document.getElementById('reg_username').value,
                Email: document.getElementById('reg_email').value,
                Password: password,
                ConfirmPassword: confirm,
                DateOfBirth: document.getElementById('reg_dob').value || null,
                Address: document.getElementById('reg_address').value 
            };

            const result = await callApi("account/register", "POST", data);

            if (result.success) {
                alert("Đăng ký thành công! Chào mừng bạn.");
                window.location.href = result.redirectUrl || "/Account/Login";
            } else {
                if (result.errors && Array.isArray(result.errors)) {
                    errorDiv.innerHTML = result.errors.join('<br>');
                } else {
                    errorDiv.textContent = result.message || "Đăng ký thất bại.";
                }
                errorDiv.classList.remove('d-none');
            }
        });
    </script>
}