@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    ViewBag.Title = "Dashboard";
    
    var summary = ViewBag.Summary as WebBanHang.DTO.Responses.DashboardSummaryDTO;
    var topProducts = ViewBag.TopProducts as List<WebBanHang.DTO.Responses.TopSellingProductDTO>;
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm bg-primary text-white h-100 py-2">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold text-white-50 mb-3">Sản phẩm</h6>
                <h3 class="fw-bold mb-0">@(summary?.TotalProducts ?? ViewBag.ProductCount ?? 0)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm bg-info text-white h-100 py-2">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold text-white-50 mb-3">Người dùng</h6>
                <h3 class="fw-bold mb-0">@(ViewBag.UserCount ?? 0)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm bg-warning text-dark h-100 py-2">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold text-dark-50 mb-3">Đơn hàng</h6>
                <h3 class="fw-bold mb-0">@(summary?.TotalOrders ?? ViewBag.OrderCount ?? 0)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm bg-success text-white h-100 py-2">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold text-white-50 mb-3">Tổng doanh thu</h6>
                <h3 class="fw-bold mb-0">@(summary?.TotalStockValue.ToString("N0") ?? "0") đ</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-7 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-secondary">Biểu đồ doanh thu năm @DateTime.Now.Year</h5>
            </div>
            <div class="card-body" style="position: relative; height:350px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-5 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-secondary">Top 5 sản phẩm bán chạy</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3 py-3">Sản phẩm</th>
                                <th class="text-center">Đã bán</th>
                                <th class="text-end pe-3">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topProducts != null && topProducts.Count > 0)
                            {
                                foreach (var prod in topProducts)
                                {
                                    <tr>
                                        <td class="ps-3 py-3 fw-bold text-truncate" style="max-width: 150px;">@prod.ProductName</td>
                                        <td class="text-center"><span class="badge bg-primary rounded-pill">@prod.TotalQuantitySold</span></td>
                                        <td class="text-end pe-3 text-danger fw-bold">@prod.TotalRevenueGenerated.ToString("N0") đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-5 fst-italic">Chưa có dữ liệu thống kê.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const labels = [@Html.Raw(ViewBag.ChartMonths ?? "''")];
        const revenueData = [@(ViewBag.ChartRevenue ?? "0")];
        const orderData = [@(ViewBag.ChartOrders ?? "0")];

        const ctx = document.getElementById('revenueChart');
        if(ctx && labels.length > 0 && labels[0] !== '') {
            new Chart(ctx.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Doanh thu (đ)',
                            data: revenueData,
                            backgroundColor: 'rgba(54, 162, 235, 0.6)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Số lượng đơn hàng',
                            data: orderData,
                            type: 'line',
                            borderColor: 'rgba(255, 159, 64, 1)',
                            backgroundColor: 'rgba(255, 159, 64, 0.2)',
                            borderWidth: 2,
                            tension: 0.3,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            type: 'linear', position: 'left',
                            ticks: { callback: value => value.toLocaleString('vi-VN') + ' đ' }
                        },
                        y1: {
                            type: 'linear', position: 'right',
                            grid: { drawOnChartArea: false }
                        }
                    }
                }
            });
        }
    });
</script>