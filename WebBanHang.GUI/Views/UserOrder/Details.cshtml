@model IEnumerable<WebBanHang.DTO.Entity.OrderDetail>
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + ViewBag.OrderId;
    Layout = "~/Views/Shared/_Layout.cshtml";
    int status = ViewBag.OrderStatus ?? 0;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold"><i class="bi bi-box-seam"></i> Chi tiết Đơn hàng #@ViewBag.OrderId</h3>
        <a href="/UserOrder/History" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="text-muted">Ngày đặt: @ViewBag.OrderDate?.ToString("dd/MM/yyyy HH:mm")</h6>
            <h6 class="mb-0">
                Trạng thái hiện tại:
                @if (status == 3)
                {
                    <span class="badge bg-success">Đã giao thành công</span>
                }
                else if (status == 2)
                {

                    <span class="badge bg-primary">Đang giao hàng</span>
                }
                else if (status == 1)
                {

                    <span class="badge bg-info text-dark">Chờ lấy hàng</span>
                }
                else if (status == 4)
                {

                    <span class="badge bg-danger">Đã hủy</span>
                }
                else
                {

                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                }
            </h6>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered align-middle text-center bg-white mb-0">
            <thead class="table-light">
                <tr>
                    <th>Hình ảnh</th>
                    <th class="text-start">Tên sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    bool isDeleted = item.Product.IsDeleted == true || item.Product.IsDeleted.ToString() == "1";

                    <tr>
                        <td>
                            <img src="/Content/images/@(item.Product?.Image ?? "default.jpg")"
                                 width="60" class="rounded shadow-sm" style="object-fit:cover;"
                                 onerror="this.src='https://placehold.co/60x60?text=No+Image'" />
                        </td>
                        <td class="text-start fw-bold">
                            @if (isDeleted)
                            {
                                <span class="text-muted">@item.Product?.Name</span>
                            }
                            else
                            {
                                <a href="/Product/Details/@item.ProductId" class="text-decoration-none text-dark">
                                    @item.Product?.Name
                                </a>
                            }
                        </td>
                        <td>@item.UnitPrice.ToString("N0") đ</td>
                        <td>@item.Quantity</td>
                        <td class="text-danger fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0")) đ</td>

                        <td>
                            @if (status == 3)
                            {
                                if (isDeleted)
                                {
                                    <div class="text-muted small fst-italic">
                                        <i class="bi bi-info-circle"></i> SP ngừng kinh doanh
                                    </div>
                                }
                                else
                                {
                                    <a href="/Product/Details/@item.ProductId" class="btn btn-sm btn-outline-warning fw-bold">
                                        <i class="bi bi-star-fill"></i> Đánh giá
                                    </a>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">Chưa thể đánh giá</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>