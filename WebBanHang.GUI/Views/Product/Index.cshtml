@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách sản phẩm";

    var ratingsJson = "{}";
    if (ViewBag.ProductRatings != null)
    {
        ratingsJson = JsonSerializer.Serialize(ViewBag.ProductRatings);
    }
}

<div class="container mt-4">
    <h2 class="mb-4">Danh sách sản phẩm</h2>

    <div class="row mb-4">
        <div class="col-md-3">
            <select id="categoryFilter" class="form-select" onchange="loadProducts()">
                <option value="">Tất cả danh mục</option>
                @if (ViewBag.CategoryList != null)
                {
                    foreach (var cat in ViewBag.CategoryList)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-6">
            <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
        </div>

        <div class="col-md-3">
            <button class="btn btn-primary w-100" onclick="loadProducts()">Tìm kiếm</button>
        </div>
    </div>

    <div id="loading" class="text-center d-none">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Đang tải sản phẩm...</p>
    </div>

    <div class="row" id="product-list">
    </div>
</div>

<script>
    const PRODUCT_API = "/api/ProductApi";

    const productRatings = @Html.Raw(ratingsJson);

    async function loadProducts() {
        const container = document.getElementById('product-list');
        const loading = document.getElementById('loading');
        const keyword = document.getElementById('searchInput').value.trim();
        const categoryId = document.getElementById('categoryFilter').value;

        loading.classList.remove('d-none');
        container.innerHTML = '';

        try {
            let url = keyword ? `${PRODUCT_API}/search?name=${encodeURIComponent(keyword)}` : `${PRODUCT_API}/details`;

            const response = await fetch(url);
            let products = await response.json();

            if (categoryId) {
                products = products.filter(p => {
                    let apiCatId = p.categoryId || p.CategoryId;
                    return String(apiCatId) === String(categoryId);
                });
            }

            if (!products || products.length === 0) {
                container.innerHTML = '<div class="col-12 text-center text-muted">Không tìm thấy sản phẩm nào thuộc danh mục này.</div>';
                return;
            }

            container.innerHTML = products.map(item => {

                const ratingInfo = productRatings[item.id || item.Id];
                let ratingHtml = '';

                const totalRevs = ratingInfo ? (ratingInfo.TotalReviews || ratingInfo.totalReviews || 0) : 0;
                const avgRating = ratingInfo ? Number(ratingInfo.AverageRating || ratingInfo.averageRating || 0) : 0;

                if (totalRevs > 0) {
                    let stars = '';
                    const roundedAvg = Math.round(avgRating);
                    for (let i = 1; i <= 5; i++) {
                        if (i <= roundedAvg) stars += '<i class="bi bi-star-fill text-warning"></i> ';
                        else stars += '<i class="bi bi-star text-warning"></i> ';
                    }
                    ratingHtml = `
                        <div class="mb-2" style="font-size: 0.85rem;">
                            ${stars}
                            <span class="text-muted fw-bold ms-1">${avgRating.toFixed(1)} (${totalRevs})</span>
                        </div>
                    `;
                } else {
                    ratingHtml = `
                        <div class="text-muted fst-italic mb-2" style="font-size: 0.85rem;">
                            <i class="bi bi-chat-left-text"></i> Chưa có đánh giá
                        </div>
                    `;
                }

                return `
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">

                        <a href="/Product/Details/${item.id || item.Id}">
                            <img src="/Content/images/${item.image || item.Image || 'default.jpg'}"
                                    class="card-img-top"
                                    style="height:200px; object-fit:cover;"
                                    onerror="this.src='https://placehold.co/400x300?text=No+Image'" />
                        </a>

                        <div class="card-body text-center d-flex flex-column">
                            <h6 class="card-title">
                                <a href="/Product/Details/${item.id || item.Id}"
                                    class="text-dark text-decoration-none fw-bold">
                                    ${item.productName || item.ProductName || item.name || item.Name}
                                </a>
                            </h6>
                            <p class="text-muted small mb-1">${item.categoryName || item.CategoryName || 'Sản phẩm'}</p>

                            ${ratingHtml}

                            <p class="fw-bold text-danger mt-auto">
                                ${Number(item.price || item.Price).toLocaleString('vi-VN')} đ
                            </p>
                            <div class="d-flex justify-content-between mt-auto pt-2">
                                <button class="btn btn-outline-danger btn-sm w-50 me-1" title="Thêm vào giỏ hàng"
                                        onclick="addToCart(${item.id || item.Id}, '${item.productName || item.ProductName || item.name || item.Name}', ${item.price || item.Price}, '${item.image || item.Image || 'default.jpg'}')">
                                    <i class="bi bi-cart-plus"></i> Giỏ hàng
                                </button>
                                <button class="btn btn-danger btn-sm w-50 ms-1"
                                        onclick="buyNow(${item.id || item.Id}, '${item.productName || item.ProductName || item.name || item.Name}', ${item.price || item.Price}, '${item.image || item.Image || 'default.jpg'}')">
                                    Mua ngay
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `}).join('');

        } catch (error) {
            console.error("Lỗi load sản phẩm:", error);
            container.innerHTML = '<div class="col-12 text-center text-danger">Có lỗi xảy ra khi tải dữ liệu. (Vui lòng kiểm tra lại đường dẫn API)</div>';
        } finally {
            loading.classList.add('d-none');
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        loadProducts();
    });

    document.getElementById('searchInput').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            loadProducts();
        }
    });

    function addToCart(id, name, price, image, showAlert = true) {
        if (!isAuthenticated) {
            alert("Bạn vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng!");
            window.location.href = '/Account/Login?ReturnUrl=' + encodeURIComponent(window.location.pathname);
            return;
        }

        let cart = JSON.parse(localStorage.getItem(CART_KEY)) || [];
        let item = cart.find(p => p.id === id);

        if (item) {
            item.quantity += 1;
        } else {
            cart.push({ id: id, name: name, price: price, image: image, quantity: 1 });
        }

        localStorage.setItem(CART_KEY, JSON.stringify(cart));

        if (typeof updateCartCount === "function") {
            updateCartCount();
        }

        if (showAlert) {
            alert(`Đã thêm "${name}" vào giỏ hàng thành công!`);
        }
    }

    function buyNow(id, name, price, image) {
        if (!isAuthenticated) {
            alert("Bạn vui lòng đăng nhập để thực hiện mua hàng!");
            window.location.href = '/Account/Login?ReturnUrl=' + encodeURIComponent(window.location.pathname);
            return;
        }

        const buyNowItem = { id: id, name: name, price: price, image: image, quantity: 1 };
        sessionStorage.setItem('buy_now_item', JSON.stringify(buyNowItem));

        sessionStorage.setItem('checkout_type', 'buy_now');
        window.location.href = '/Cart';
    }

    document.addEventListener("DOMContentLoaded", updateCartCount);
</script>