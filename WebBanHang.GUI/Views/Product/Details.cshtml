@model WebBanHang.DTO.Entity.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-5">
            <img src="/Content/images/@Model.Image" class="img-fluid rounded shadow-sm" onerror="this.src='https://placehold.co/400x400?text=No+Image'" />
        </div>
        <div class="col-md-7">
            <h2 class="fw-bold">@Model.Name</h2>
            <p class="text-danger fs-2 fw-bold mt-3">@Model.Price.ToString("N0") đ</p>
            <button class="btn btn-success btn-lg mt-3 px-5"
                     onclick="addToCart(@Model.Id, '@Html.Raw(Model.Name)', @((int)Model.Price), '@Model.Image')">
                <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
            </button>
        </div>
    </div>

    <hr class="my-5" />

    <div class="row">
        <div class="col-md-7">
            <h4 class="mb-4">Khách hàng đánh giá</h4>
            <div class="review-list" style="max-height: 500px; overflow-y: auto;">
                
                @if (ViewBag.Reviews != null && ((System.Collections.IList)ViewBag.Reviews).Count > 0)
                {
                    foreach (var rev in ViewBag.Reviews)
                    {
                        <div class="card mb-3 shadow-sm border-0 bg-light">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <strong class="text-primary"><i class="bi bi-person-circle"></i> @rev.UserEmail</strong>
                                    <span class="text-muted small">@rev.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star-fill @(i <= rev.Rating ? "text-warning" : "text-muted")"></i>
                                    }
                                </div>
                                <p class="mb-0 text-dark">@rev.Content</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted fst-italic">Chưa có đánh giá nào cho sản phẩm này.</p>
                }
            </div>
        </div>

        <div class="col-md-5">  
            @if (ViewBag.CanReview == true)
            {
                var myRev = ViewBag.MyReview as WebBanHang.DTO.Entity.Review;
                bool isEdit = myRev != null;

                <h4 class="mb-4">@(isEdit ? "Chỉnh sửa đánh giá của bạn" : "Viết đánh giá mới")</h4>

                <div class="card p-4 shadow-sm border-0 bg-light">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn số sao:</label>
                        <select id="lblRating" class="form-select border-warning">
                            <option value="5" selected="@(isEdit && myRev!.Rating == 5)">⭐⭐⭐⭐⭐ Tuyệt vời</option>
                            <option value="4" selected="@(isEdit && myRev!.Rating == 4)">⭐⭐⭐⭐ Tốt</option>
                            <option value="3" selected="@(isEdit && myRev!.Rating == 3)">⭐⭐⭐ Bình thường</option>
                            <option value="2" selected="@(isEdit && myRev!.Rating == 2)">⭐⭐ Kém</option>
                            <option value="1" selected="@(isEdit && myRev!.Rating == 1)">⭐ Quá tệ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung:</label>
                        <textarea id="txtReviewContent" class="form-control" rows="4" placeholder="Sản phẩm này thế nào?">@(isEdit ? myRev!.Content : "")</textarea>
                    </div>
                    <button class="btn btn-warning w-100 fw-bold text-white shadow-sm" onclick="sendReview(@Model.Id)">
                        @(isEdit ? "Cập nhật đánh giá" : "Gửi Đánh Giá")
                    </button>
                </div>
            }
            else
            {
                <h4 class="mb-4">Viết đánh giá</h4>
                <div class="alert alert-secondary text-center py-5 shadow-sm border-0">
                    <i class="bi bi-lock-fill fs-1 text-muted d-block mb-3"></i>
                    <h5 class="fw-bold">Chức năng bị khóa</h5>
                    <p class="text-muted mb-0 small">Bạn cần mua và nhận hàng thành công sản phẩm này mới có thể để lại bình luận.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(id, name, price, image) {
            
            let isLogin = @(User.Identity != null && User.Identity.IsAuthenticated ? "true" : "false");

            if (!isLogin) {
                alert("Bạn vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng!");
                const currentUrl = encodeURIComponent(window.location.pathname + window.location.search);
                window.location.href = '/Account/Login?ReturnUrl=' + currentUrl;
                return;
            }

            let cart = JSON.parse(localStorage.getItem(CART_KEY)) || [];
            let item = cart.find(p => p.id === id);

            if (item) {
                item.quantity += 1;
            } else {
                cart.push({ id: id, name: name, price: price, image: image, quantity: 1 });
            }

            localStorage.setItem(CART_KEY, JSON.stringify(cart));

            if (typeof updateCartCount === "function") {
                updateCartCount();
            }

            alert(`Đã thêm "${name}" vào giỏ hàng thành công!`);
        }

        function sendReview(productId) {
            const content = document.getElementById("txtReviewContent").value.trim();
            const rating = document.getElementById("lblRating").value;

            if (!content) {
                alert("Vui lòng nhập nội dung đánh giá!");
                return;
            }

            const payload = {
                productId: productId,
                rating: parseInt(rating),
                content: content
            };

            fetch('/api/ReviewApi/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("🎉 " + data.message);
                    window.location.reload();
                } else {
                    alert("Lỗi: " + data.message);
                }
            })
            .catch(err => {
                console.error(err);
                alert("Đã xảy ra lỗi kết nối!");
            });
        }
    </script>
}